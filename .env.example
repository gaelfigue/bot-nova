# ══════════════════════════════════════════════════
# NOVA_CORE — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ══════════════════════════════════════════════════

# ─── Telegram Bot ────────────────────────────────
# Obtén tu token en https://t.me/BotFather
TELEGRAM_TOKEN=tu_token_de_botfather_aqui

# ─── Audio Processing ───────────────────────────
# Target LUFS para normalización (estándar streaming/DJ)
TARGET_LUFS=-14.0

# Peak Limit en dBTP (evita clipping en cabina)
PEAK_LIMIT_DBTP=-1.0

# Bitrate del MP3 final
MP3_BITRATE=320

# ─── Límites ────────────────────────────────────
# Tamaño máximo de archivo (límite Telegram = 50MB)
MAX_FILE_SIZE_MB=50

# Descargas simultáneas máximas en el servidor
MAX_CONCURRENT_DOWNLOADS=3

# ─── Logging ────────────────────────────────────
# Niveles: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── IA - Google Gemini ─────────────────────────────────────
# Consigue tu key gratis en https://aistudio.google.com/
GEMINI_API_KEY=tu_gemini_api_key_aqui

